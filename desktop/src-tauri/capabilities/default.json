{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Allow the main terminal window to use Tauri IPC for the PTY bridge.",
  "windows": ["main", "terminal-window-*"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:webview:allow-create-webview-window",
    "allow-terminal-open",
    "allow-terminal-open-runtime",
    "allow-terminal-open-docker-app",
    "allow-terminal-write",
    "allow-terminal-resize",
    "allow-terminal-kill",
    "allow-terminal-eof",
    "allow-terminal-kill-all",
    "allow-terminal-smoke-command",
    "allow-terminal-smoke-ctrl-d-delay-ms",
    "allow-terminal-smoke-frontend-config",
    "allow-terminal-write-smoke-frontend-evidence",
    "allow-runtime-inventory",
    "allow-wsl-ubuntu-install",
    "allow-apt-package-catalog",
    "allow-apt-update",
    "allow-apt-package-install",
    "allow-docker-desktop-install",
    "allow-docker-image-pull",
    "allow-docker-app-catalog",
    "allow-docker-app-pull",
    "allow-ai-cli-install",
    "allow-ai-cli-update"
  ]
}
