{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Terminal",
  "mainBinaryName": "ai-terminal",
  "version": "0.3.2",
  "identifier": "dev.aiterminal.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Terminal",
        "width": 1040,
        "height": 720,
        "minWidth": 640,
        "minHeight": 420,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "targets": ["nsis", "msi"],
    "resources": []
  }
}
